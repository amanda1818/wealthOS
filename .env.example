# Client-side env (loaded by vite.config.ts, safe to ship in the bundle --
# protection comes from Postgres RLS, not from hiding this key).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# GEMINI_API_KEY is NOT read by the client. Set it as a Supabase Edge
# Function secret instead, on the machine/CI running `supabase` CLI:
#   supabase secrets set GEMINI_API_KEY=your-gemini-key
#   supabase secrets set AI_DAILY_REQUEST_LIMIT=150   # optional, defaults to 150
